{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/update-password/(.*)",
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-store"
      }
    },
    {
      "src": "/(.*)", 
      "dest": "/index.html"
    }
  ]
}